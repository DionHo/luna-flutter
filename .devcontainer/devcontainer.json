{
  "name": "Luna Flutter",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "..",
    // Override to pin a specific Flutter release tag, e.g. "3.29.3"
    "args": {
      "FLUTTER_CHANNEL": "stable"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        // Dart & Flutter language support
        "dart-code.dart-code",
        "dart-code.flutter",
        // Git history visualiser
        "mhutchie.git-graph",
        // GitHub Copilot AI pair-programming
        "github.copilot-chat"
      ],
      "settings": {
        "dart.flutterSdkPath": "/opt/flutter",
        "[dart]": {
          "editor.formatOnSave": true,
          "editor.rulers": [80]
        }
      }
    }
  },
  "remoteUser": "vscode",
  // Make scripts executable and pull pub dependencies on first container start.
  "postCreateCommand": "chmod +x scripts/*.sh && flutter pub get"
}
